{
  "name": "clair-mcp-server",
  "version": "1.0.0",
  "description": "CLAIR — Cascaded Lazy AI Routing. MCP server that reduces token burn by lazily loading skills and routing subtasks to ML backends.",
  "main": "dist/stdio.js",
  "bin": {
    "clair-mcp": "dist/stdio.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/concensure/clair-mcp-server.git"
  },
  "homepage": "https://github.com/concensure/clair-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/concensure/clair-mcp-server/issues"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/stdio.js",
    "start:http": "node dist/server.js",
    "dev": "ts-node src/stdio.ts",
    "dev:http": "ts-node src/server.ts"
  },
  "keywords": [
    "mcp",
    "clair",
    "routing",
    "skills",
    "lazy-loading",
    "token-savings",
    "llm",
    "ai-agent"
  ],
  "author": "Casper Wu",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6",
    "@types/node": "^20.4.5"
  }
}
