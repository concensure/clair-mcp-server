PORT=3003

# Which LLM provider your own app uses.
# Options: openrouter | openai | gemini | anthropic
LLM_PROVIDER=openrouter

# OpenRouter (recommended for this demo)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here
OPENROUTER_MODEL=openrouter/auto

# Optional: other providers (not used unless LLM_PROVIDER is set accordingly)
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4.1-mini

GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.0-flash

ANTHROPIC_API_KEY=your-claude-key-here
ANTHROPIC_MODEL=claude-3.7-sonnet

# URL where CLAIR MCP server is running (optional — for MCP integration)
CLAIR_MCP_URL=http://localhost:3001/mcp
